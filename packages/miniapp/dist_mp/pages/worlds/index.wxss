.container{padding:24rpx}.page-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:flex-start;justify-content:space-between;-ms-flex-align:start;align-items:flex-start;gap:16rpx}.title{display:block;font-size:36rpx;font-weight:700}.subtitle{color:#999;display:block;font-size:22rpx;margin-top:6rpx}.refresh-btn{border:2rpx solid #333;border-radius:14rpx;color:#ccc;-webkit-flex-shrink:0;padding:14rpx 20rpx;-ms-flex-negative:0;flex-shrink:0}.empty-card,.intro-card,.world-card{background:hsla(0,0%,100%,.02);border:2rpx solid #222;border-radius:18rpx;margin-top:20rpx;padding:20rpx}.detail-title,.empty-title,.intro-title,.world-title{display:block;font-size:28rpx;font-weight:600}.empty-text,.intro-text,.reason-text,.world-subtitle{color:#999;display:block;font-size:22rpx;margin-top:8rpx}.filter-row{margin-top:20rpx}.filter-label{color:#999;display:block;font-size:22rpx;margin-bottom:10rpx}.filter-scroll{white-space:nowrap}.chip-row{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:12rpx}.chip{border:2rpx solid #333;border-radius:999rpx;color:#aaa;display:-webkit-inline-flex;display:-ms-inline-flexbox;display:inline-flex;padding:10rpx 18rpx}.chip.active{background:rgba(124,58,237,.12);border-color:#7c3aed;color:#7c3aed}.chip.danger{background:rgba(239,68,68,.12);border-color:rgba(239,68,68,.45);color:#f87171}.chip text{font-size:22rpx}.world-list{padding-bottom:24rpx}.world-summary{-webkit-align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:16rpx;-ms-flex-align:start;align-items:flex-start}.world-rank{-webkit-align-items:center;background:rgba(124,58,237,.16);border-radius:50%;color:#7c3aed;display:-webkit-flex;display:-ms-flexbox;display:flex;height:56rpx;width:56rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;-webkit-flex-shrink:0;justify-content:center;-ms-flex-negative:0;flex-shrink:0;font-size:28rpx;font-weight:700}.world-main{-webkit-flex:1;-ms-flex:1;flex:1;min-width:0}.badge-stack{-webkit-align-items:flex-end;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:8rpx;-ms-flex-align:end;align-items:flex-end}.badge{border:1rpx solid #444;border-radius:999rpx;color:#ccc;font-size:20rpx;padding:6rpx 12rpx}.badge.danger{border-color:rgba(239,68,68,.45);color:#f87171}.world-card.invalid{border-color:rgba(239,68,68,.28);opacity:.72}.world-detail{border-top:1rpx solid #2a2a2a;margin-top:16rpx;padding-top:16rpx}.assignment-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:10rpx;margin-top:10rpx}.assignment-pill{border-radius:12rpx;font-size:22rpx;padding:10rpx 14rpx}.assignment-pill.evil{background:rgba(239,68,68,.12);color:#f87171}.assignment-pill.good{background:rgba(59,130,246,.12);color:#60a5fa}.reason-block{margin-top:16rpx}.danger-text{color:#f87171}.empty{padding:80rpx 0;text-align:center}.empty text{color:#666;font-size:26rpx}